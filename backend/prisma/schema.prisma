generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MODÈLES
// ============================================================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fournisseurs    Fournisseur[]
  ingredients     Ingredient[]
  receptions      ReceptionFacture[]
  menus           Menu[]
  menuIngredients MenuIngredient[]
  nettoyages      Nettoyage[]
  temperatures    SuiviTemperature[]
  configurations  Configuration[]
  userTenants     UserTenant[]

  @@map("tenants")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  nom       String?
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userTenants  UserTenant[]
  nettoyages   Nettoyage[]
  temperatures SuiviTemperature[]

  @@map("users")
}

model UserTenant {
  id        String   @id @default(cuid())
  role      String   @default("USER")
  createdAt DateTime @default(now()) @map("created_at")

  userId   String  @map("user_id")
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId String? @map("tenant_id")
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("user_tenants")
}

model Fournisseur {
  id               String    @id @default(cuid())
  nom              String?
  nomContact       String?   @map("nom_contact")
  adresse          String?
  email            String?
  telephone        String?
  type             String?
  evaluation       Int?
  notes            String?
  bio              Boolean   @default(false)
  certificateur    String?
  numeroCertificat String?   @map("numero_certificat")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  receptions ReceptionFacture[]

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("fournisseurs")
}

model ReceptionFacture {
  id          String    @id @default(cuid())
  numeroPiece String?   @map("numero_piece")
  dateAchat   DateTime? @map("date_achat")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  fournisseurs Fournisseur[]
  ingredients  Ingredient[]

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("reception_factures")
}

model Ingredient {
  id                  String   @id @default(cuid())
  nom                 String?
  origine             String?
  bio                 Boolean  @default(false)
  prixTotal           Decimal? @map("prix_total")
  stockReception      Decimal? @map("stock_reception")
  unite               String?
  // Stored as JSON array string: '["GLUTEN","LAIT"]'
  allergenes          String   @default("[]") @map("allergenes")
  evaluationReception Int?     @map("evaluation_reception")
  notes               String?
  epuise              Boolean  @default(false)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  lotId           String?           @map("lot_id")
  lot             ReceptionFacture? @relation(fields: [lotId], references: [id])
  menuIngredients MenuIngredient[]

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("ingredients")
}

model Menu {
  id                  String    @id @default(cuid())
  nom                 String?
  date                DateTime
  typeRepas           String?   @map("type_repas")
  description         String?
  nbCouvertsPrevus    Int       @map("nb_couverts")
  nbCouvertsReels     Int?      @map("nb_couverts_reels")
  nbCouvertsBenevoles Int?      @map("nb_couverts_benevoles")
  nbBenevoles         Int       @default(0) @map("nb_benevoles")
  heuresBenevoles     Decimal   @default(0) @map("heures_benevoles")
  chiffreAffaires     Decimal?  @map("chiffre_affaires")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  ingredients MenuIngredient[]

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([date])
  @@map("menus")
}

model MenuIngredient {
  id           String   @id @default(cuid())
  quantite     Decimal
  unite        String?
  prixUnitaire Decimal? @map("prix_unitaire")
  coursType    String?  @map("cours_type")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  menuId       String     @map("menu_id")
  menu         Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  ingredientId String     @map("ingredient_id")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([menuId, ingredientId])
  @@index([tenantId])
  @@map("menu_ingredients")
}

model Nettoyage {
  id            String    @id @default(cuid())
  date          DateTime
  typeNettoyage String?   @map("type_nettoyage")
  zone          String?
  conforme      Boolean   @default(true)
  notes         String?
  prevu         Boolean   @default(false)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  utilisateurId String? @map("utilisateur_id")
  utilisateur   User?   @relation(fields: [utilisateurId], references: [id])

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([date])
  @@map("nettoyages")
}

model SuiviTemperature {
  id             String   @id @default(cuid())
  date           DateTime
  equipement     String
  temperature    Decimal
  temperatureMin Decimal? @map("temperature_min")
  temperatureMax Decimal? @map("temperature_max")
  conformite     Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  utilisateurId String? @map("utilisateur_id")
  utilisateur   User?   @relation(fields: [utilisateurId], references: [id])

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([date])
  @@map("suivi_temperatures")
}

model Configuration {
  id        String   @id @default(cuid())
  category  String
  key       String
  label     String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, category, key])
  @@index([tenantId, category])
  @@map("configurations")
}
